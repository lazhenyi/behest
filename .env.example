# ── behest runtime configuration ──────────────────────────────
# Prefix convention: BEHEST__<SECTION>__<KEY>=<value>
# Set via AgentConfigBuilder::with_env("BEHEST") in your binary.

# ── Providers ──────────────────────────────────────────────────
# Register one or more providers. The ID (e.g. OPENAI) is your
# chosen key; nest config under it.
#
# API keys support the env: prefix for indirect reference:
#   BEHEST__PROVIDERS__OPENAI__API_KEY=env:OPENAI_API_KEY

# BEHEST__PROVIDERS__OPENAI__PROVIDER_TYPE=openai
# BEHEST__PROVIDERS__OPENAI__BASE_URL=https://api.openai.com/v1
# BEHEST__PROVIDERS__OPENAI__API_KEY=env:OPENAI_API_KEY
# BEHEST__PROVIDERS__OPENAI__MODEL=gpt-4o
# BEHEST__PROVIDERS__OPENAI__TIMEOUT_SECS=60

# BEHEST__PROVIDERS__ANTHROPIC__PROVIDER_TYPE=anthropic
# BEHEST__PROVIDERS__ANTHROPIC__BASE_URL=https://api.anthropic.com/v1
# BEHEST__PROVIDERS__ANTHROPIC__API_KEY=env:ANTHROPIC_API_KEY
# BEHEST__PROVIDERS__ANTHROPIC__MODEL=claude-sonnet-4-20250514

# ── Stores ─────────────────────────────────────────────────────
# Backend: memory (default) | redis | sql | mongo | surreal

# BEHEST__STORES__SESSION_BACKEND=memory
# BEHEST__STORES__EXECUTION_BACKEND=memory
# BEHEST__STORES__RUN_BACKEND=memory
# BEHEST__STORES__EMBEDDING_BACKEND=memory
# BEHEST__STORES__ARTIFACT_BACKEND=memory

# Redis (requires feature = "redis")
# BEHEST__STORES__REDIS_URL=redis://127.0.0.1:6379

# PostgreSQL (requires feature = "sqlx-postgres")
# BEHEST__STORES__SQL_URL=postgres://user:pass@localhost/behest

# MongoDB (requires feature = "mongodb")
# BEHEST__STORES__MONGO_URL=mongodb://localhost:27017

# SurrealDB (requires feature = "surrealdb")
# BEHEST__STORES__SURREAL_URL=ws://localhost:8000

# ── Queue (requires feature = "queue") ─────────────────────────
# Backend: nats | redis_streams

# BEHEST__QUEUE__BACKEND=nats
# BEHEST__QUEUE__NATS_URL=nats://localhost:4222
# BEHEST__QUEUE__NATS_SUBJECT=behest.events

# ── RAG (requires feature = "rag") ─────────────────────────────

# BEHEST__RAG__PROVIDER_ID=openai
# BEHEST__RAG__MODEL=text-embedding-3-small
# BEHEST__RAG__LIMIT=5
# BEHEST__RAG__QDRANT_URL=http://localhost:6334
# BEHEST__RAG__QDRANT_COLLECTION=behest

# ── Runtime policy ─────────────────────────────────────────────

# BEHEST__RUNTIME__MAX_HISTORY_MESSAGES=50
# BEHEST__RUNTIME__EVENT_CHANNEL_CAPACITY=256
# BEHEST__RUNTIME__SNAPSHOT_DIR=./snapshots
# BEHEST__RUNTIME__POLICY__MAX_ITERATIONS=10
# BEHEST__RUNTIME__POLICY__MAX_TOOL_CONCURRENCY=4
# BEHEST__RUNTIME__POLICY__TOOL_TIMEOUT_SECS=30
# BEHEST__RUNTIME__POLICY__PROVIDER_TIMEOUT_SECS=60
# BEHEST__RUNTIME__POLICY__CONTINUE_ON_TOOL_FAILURE=true
# BEHEST__RUNTIME__POLICY__RETRY_ON_PROVIDER_ERROR=true
# BEHEST__RUNTIME__POLICY__MAX_RETRIES=2

# ── TLS ────────────────────────────────────────────────────────
# Uncomment to use native TLS instead of rustls (default):
# BEHEST__TLS=rustls

# ── Logging ────────────────────────────────────────────────────
# RUST_LOG=behest=debug,info
